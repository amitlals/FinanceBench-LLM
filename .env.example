# FinanceBench-LLM Environment Variables
# Copy this file to .env and fill in your values

# NVIDIA NIM API Key (optional — only needed for running notebooks locally)
# Get yours free at: https://build.nvidia.com
# NVIDIA_API_KEY=nvapi-YOUR_KEY_HERE

# Hugging Face Token (required for HF Space demo and dataset access)
# Get yours free at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_YOUR_TOKEN_HERE

# MLflow Tracking URI (default: local SQLite database)
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# NeMo Customizer URL (only needed for LoRA training via NeMo)
# NEMO_CUSTOMIZER_URL=http://localhost:8000
